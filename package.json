{
  "name": "elementum",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint:check": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write",
    "typecheck": "vue-tsc",
    "verify": "bun run format && bun run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline:collect": "bun run scripts/collect-data.ts",
    "pipeline:merge": "bun run scripts/merge.ts",
    "pipeline": "bun run pipeline:collect && bun run pipeline:merge",
    "pipeline:validate": "bun run scripts/validate-enrichment.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tresjs/cientos": "^5.7.0",
    "@tresjs/core": "^5.8.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "apexcharts": "^5.10.5",
    "focus-trap": "^8.0.1",
    "gsap": "^3.14.2",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.3.8",
    "vue-router": "^5.0.4",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@pinia/testing": "^1.0.3",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
